# ─────────────────────────────────────────────────────────────────────────────
# CareerVolt Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values
#
# 🚀 Production deployment:
#   Frontend → Vercel
#   Backend  → Render (Python FastAPI)
#   Auth     → Render (Node/Express)
#   DB       → MongoDB Atlas (already configured)
# ─────────────────────────────────────────────────────────────────────────────

# ─── Backend (Python FastAPI) ────────────────────────────────────────
# Groq API key — get yours free at https://console.groq.com
# Python backend reads this via os.getenv("GROQ_API_KEY")
GROQ_API_KEY=your_groq_api_key_here

# ─── Frontend (Vite — must be prefixed with VITE_) ───────────────────

# Groq API key for client-side interview question generation
# ⚠️  Exposed to browser — consider moving to backend-only in production
VITE_GROQ_API_KEY=your_groq_api_key_here

# Google OAuth Client ID (from https://console.cloud.google.com)
# Required for "Continue with Google" button
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Auth server URL (used in dev; production uses vercel.json rewrites)
VITE_AUTH_URL=http://localhost:3001

# Backend API URL (used in dev; production uses vercel.json rewrites)
VITE_API_URL=http://localhost:8000

# ─── Production URLs (update vercel.json after deploying services) ───
# After deploying to Render, update vercel.json with your actual URLs:
#   "https://careervolt-api.onrender.com"   → Python backend
#   "https://careervolt-auth.onrender.com"  → Auth server
