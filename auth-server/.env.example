# ─── Auth Server Environment Variables ────────────────────────
# Copy this file to .env and fill in your values
#
# 🚀 Production deployment (Render):
#   1. Create a Web Service on Render
#   2. Set these env vars in Render dashboard
#   3. Set CLIENT_URL to your Vercel frontend URL
# ─────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────
# Cloud MongoDB Atlas (already configured for CareerVolt):
MONGO_URI=mongodb+srv://cmgaming351_db_user:NHqSGNvd5DpFktg9@cluster0.1umyjor.mongodb.net/careervolt
# Local MongoDB (dev):
# MONGO_URI=mongodb://127.0.0.1:27017/caai_auth

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=caa7d8f3b1e94c5a8f2d6b0e3a7c9d1e4f8a2b5c0d3e6f9a1b4c7d0e2f5a8b1
JWT_EXPIRES_IN=7d

# ── Google OAuth ──────────────────────────────────────────────
# REQUIRED for Google Sign-In to work
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here

# ── Frontend URL (for CORS) ───────────────────────────────────
# Development:
CLIENT_URL=http://localhost:5173
# Production (set this on Render):
# CLIENT_URL=https://careervolt.vercel.app
